# apps/mobile/.env.example — Template pour l'app mobile (Expo)
# Copier ce fichier en .env.local et remplir les valeurs marquées ⚠️
# Ne jamais committer .env.local

# URL de l'API backend
# Simulateur macOS : http://localhost:8000
# Device physique : http://<IP-locale>:8000 — obtenir avec : ipconfig getifaddr en0
# En prod : https://cordeau-api.fly.dev
EXPO_PUBLIC_API_URL=http://localhost:8000

# Google OAuth (flow mobile expo-auth-session)
# Client iOS à récupérer dans Google Cloud Console → projet Cordeau
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=      # ⚠️ À mettre dans .env.local

# Sentry — DSN à récupérer dans https://cordeau.sentry.io → projet "cordeau-mobile"
EXPO_PUBLIC_SENTRY_DSN=                # ⚠️ DSN public mais env-specific — dans .env.local pour ne pas mélanger les envs
EXPO_PUBLIC_SENTRY_ENVIRONMENT=development
