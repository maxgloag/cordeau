# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> app/auth ###
# Ouverture de l'inscription self-service (cf ADR 0021).
# Defaut SUR : false => inscription fermee (beta privee, onboarding via app:user:create).
# Prod reste fermee meme si le secret Fly n'est pas pose. Dev/test ouvrent via .env.dev / .env.test.
# Reouverture self-service (V1) : fly secrets set REGISTRATION_SELF_SERVICE_ENABLED=true
REGISTRATION_SELF_SERVICE_ENABLED=false
###< app/auth ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=18&charset=utf8"
###< doctrine/doctrine-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$
###< nelmio/cors-bundle ###

###> knpuniversity/oauth2-client-bundle ###
# Google OAuth 2.0 — credentials a fournir dans .env.local (dev) ou via env (prod)
# Pour creer les credentials : https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Pour le flow mobile (POST /auth/oauth/google/exchange) : liste CSV des Client IDs
# valides (au moins le iOS, et eventuellement le web si on autorise un usage mobile-side).
# Vide => aucune audience acceptee => le endpoint exchange refuse tout id_token.
GOOGLE_OAUTH_AUDIENCES=
# URL frontend vers laquelle rediriger apres login OAuth web
WEB_APP_URL=http://localhost:5173
###< knpuniversity/oauth2-client-bundle ###

###> sentry/sentry-symfony ###
SENTRY_DSN=
SENTRY_ENVIRONMENT=dev
###< sentry/sentry-symfony ###

###> app/storage ###
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET=cordeau-photos
R2_PUBLIC_URL=https://photos.cordeau.app
###< app/storage ###
