# apps/api/.env.example — Template pour l'API Symfony
# Copier ce fichier en .env.local et remplir les valeurs marquées ⚠️
# Ne jamais committer .env.local

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=                    # ⚠️ Générer avec : openssl rand -hex 32
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> doctrine/doctrine-bundle ###
# En dev : postgresql://cordeau:cordeau@127.0.0.1:5432/cordeau
DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=18&charset=utf8"
###< doctrine/doctrine-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$
###< nelmio/cors-bundle ###

###> knpuniversity/oauth2-client-bundle ###
# Google OAuth — credentials à récupérer dans Google Cloud Console (projet Cordeau)
# Client dev : https://console.cloud.google.com/apis/credentials (chercher "cordeau-dev")
GOOGLE_CLIENT_ID=<dev_client_id>       # non-secret, peut rester ici
GOOGLE_CLIENT_SECRET=                  # ⚠️ À mettre dans .env.local uniquement
GOOGLE_OAUTH_AUDIENCES=                # ⚠️ iOS client ID(s) — dans .env.local
WEB_APP_URL=http://localhost:5173
###< knpuniversity/oauth2-client-bundle ###

###> sentry/sentry-symfony ###
# DSN à récupérer dans https://cordeau.sentry.io → projet "cordeau-api" → Settings → Client Keys
SENTRY_DSN=                            # ⚠️ À mettre dans .env.local (DSN non-secret mais env-specific)
SENTRY_ENVIRONMENT=dev
###< sentry/sentry-symfony ###
