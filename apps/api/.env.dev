
###> symfony/framework-bundle ###
# APP_SECRET doit être défini dans .env.local (non commité)
# Générer avec : php -r "echo bin2hex(random_bytes(16));"
###< symfony/framework-bundle ###

###> app/auth ###
# En dev, l'inscription self-service est ouverte (cf ADR 0021).
REGISTRATION_SELF_SERVICE_ENABLED=true
###< app/auth ###
