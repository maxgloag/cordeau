# apps/web/.env.example — Template pour l'app web (Vite + React)
# Copier ce fichier en .env.local et remplir les valeurs marquées ⚠️
# Ne jamais committer .env.local

# URL de l'API backend
# En dev : laisser vide — le proxy Vite route vers localhost:8000 automatiquement
# En prod : https://cordeau-api.fly.dev
VITE_API_URL=

# Sentry — DSN à récupérer dans https://cordeau.sentry.io → projet "cordeau-web"
VITE_SENTRY_DSN=                       # ⚠️ DSN public mais env-specific — dans .env.local pour ne pas mélanger les envs
VITE_SENTRY_ENVIRONMENT=development
