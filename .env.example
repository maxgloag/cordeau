# Variables racines partagées par les apps en dev local.
# Copier en .env (jamais commit) et adapter si besoin.

# Postgres (docker-compose)
POSTGRES_USER=cordeau
POSTGRES_PASSWORD=cordeau
POSTGRES_DB=cordeau
POSTGRES_PORT=5432

# Redis (docker-compose) — décalé à 6380 pour cohabiter avec d'autres projets locaux
REDIS_PORT=6380
